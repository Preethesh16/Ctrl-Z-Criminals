# Copy this file to .env and fill in real values. .env is git-ignored —
# never commit real credentials. See dbguide.md for full setup instructions.

# --- Database ---
DATABASE_URL=postgresql+psycopg://tracenet:tracenet@localhost:5432/tracenet

# --- LLM assist (OPTIONAL — system is fully functional without it) ---
LLM_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- App ---
SECRET_KEY=change-me-to-a-long-random-string
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
